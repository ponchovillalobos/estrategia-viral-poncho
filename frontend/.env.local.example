# =============================================================================
# Configuración local del dashboard Estrategia Viral Poncho
# =============================================================================
# Copiá este archivo a `.env.local` y completá los valores.
# Solo PEXELS_API_KEY es obligatorio. El resto son opcionales (overrides).
# =============================================================================

# ─── OBLIGATORIO ─────────────────────────────────────────────────────────────

# Pexels API key — obtenela GRATIS sin tarjeta en https://www.pexels.com/api/new/
# Sin esto el buscador de B-roll del editor no funciona.
PEXELS_API_KEY=


# ─── LLMs para captions virales — TODO POR OAUTH (sin API keys) ──────────────
# El generador de captions usa CLIs autenticadas vía OAuth con tus suscripciones
# existentes. NO requiere API keys ni variables de entorno acá.
#
# Auto-detección (orden de preferencia):
#   1. claude — Claude Code CLI (suscripción Claude.ai Pro/Max)
#      Instalar: npm install -g @anthropic-ai/claude-code  &&  claude login
#   2. codex — OpenAI Codex CLI (suscripción ChatGPT Plus)
#      Instalar: npm install -g @openai/codex  &&  codex login
#   3. ollama — qwen3:1.7b local (fallback gratis, calidad básica)
#
# El detector mira `shutil.which("claude")` y `shutil.which("codex")` en PATH.
# Si ninguno está instalado, cae a Ollama automáticamente.


# ─── OPCIONAL: overrides de paths (solo si tu setup es no-estándar) ──────────

# Path al root del proyecto. Default: 1 nivel arriba de frontend/.
# VIRAL_PROJECT_ROOT=C:\code\Estrategia_Viral_Poncho

# Path al directorio de datos. Default: auto-detect entre C:\viral-data\videos
# y C:\hermes-data\videos (este último por compat con setup viejo).
# VIRAL_DATA_ROOT=D:\data\viral\videos

# Path a ffmpeg.exe y ffprobe.exe. Default: auto-detect en {DATA_ROOT}/../tools/ffmpeg-*/bin/
# VIRAL_FFMPEG_EXE=C:\Program Files\ffmpeg\bin\ffmpeg.exe
# VIRAL_FFPROBE_EXE=C:\Program Files\ffmpeg\bin\ffprobe.exe

# Host del dev server (para que Remotion sirva videos/SFX). Default: http://localhost:3000
# VIRAL_API_HOST=http://localhost:3000

# Base URL pública para los redirect URIs de OAuth (LinkedIn/Instagram). Default:
# http://localhost:3000. Cambiala solo si servís la app en otro host/puerto.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
